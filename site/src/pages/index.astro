---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Vitor Margis" description="Software Engineer & Engineering Manager based in Amsterdam">
  <section class="hero">
    <div class="hero-inner">
      <div class="photo-wrap">
        <div class="carousel-slides">
          <img src="/hero1.png" class="carousel-slide active" alt="Vitor Margis" width="250" height="250" />
          <img src="/hero2.png" class="carousel-slide" alt="Vitor Margis" width="250" height="250" />
          <img src="/hero3.png" class="carousel-slide" alt="Vitor Margis" width="250" height="250" />
          <img src="/hero4.png" class="carousel-slide" alt="Vitor Margis" width="250" height="250" />
        </div>
      </div>

      <div class="hero-text">
        <h1 class="headline">
          HI, I'M <span class="accent">VITOR MARGIS</span>
        </h1>
        <h2 class="role">
          SOFTWARE ENGINEER &amp; ENGINEERING MANAGER at <span class="accent">ANGI</span>
          {' '}/<br class="role-break" />
          MENTORING at <span class="accent">ADPList</span>
        </h2>
        <p class="tagline">SHARING &amp; BUILDING FOR THE WEB</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 56px);
    padding: 2rem;
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 3.5rem;
    max-width: 1000px;
    width: 100%;
    margin-top: -100px;
  }

  /* Carousel */
  .photo-wrap {
    flex-shrink: 0;
  }

  .carousel-slides {
    position: relative;
    width: 250px;
    height: 250px;
    border-radius: 50%;
    overflow: hidden;
    border: 11px solid #151515;
    box-shadow: 0px 0px 0px 5px #fff;
  }

  .carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 250px;
    height: 250px;
    object-fit: cover;
    object-position: center top;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .carousel-slide.active {
    opacity: 1;
  }

  /* Text block */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .headline {
    font-size: clamp(2rem, 5vw, 2.6rem);
    letter-spacing: 0;
    line-height: 1.4;
    color: var(--color-text);
  }

  .accent {
    color: var(--color-accent);
  }

  .role {
    font-size: clamp(0.85rem, 2vw, 2.6rem);
    letter-spacing: 0em;
    color: var(--color-text);
    line-height: 1.4;
  }

  .role-break {
    display: none;
  }

  .tagline {
    font-size: clamp(0.75rem, 1.5vw, 1.2rem);
    letter-spacing: 0.2em;
    font-weight: 200;
    color: #555555;
    font-variant: small-caps;
    margin-top: 1rem;
  }

  /* Mobile layout: stack vertically */
  @media (max-width: 640px) {
    .hero {
      align-items: flex-start;
      padding-top: 2.5rem;
    }

    .hero-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .carousel-slides {
      width: 160px;
      height: 160px;
    }

    .carousel-slide {
      width: 160px;
      height: 160px;
    }

    .role-break {
      display: inline;
    }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  let current = 0;

  function go(n: number) {
    slides[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
  }

  setInterval(() => go(current + 1), 4000);
</script>
