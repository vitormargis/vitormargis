---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gear">
  <div class="page-stub">
    <p class="label">GEAR</p>
  </div>
</BaseLayout>

<style>
  .page-stub {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 56px);
  }

  .label {
    font-size: 1.2rem;
    font-weight: 100;
    letter-spacing: 0.2em;
    color: var(--color-text);
  }
</style>
