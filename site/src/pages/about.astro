---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Vitor Margis — Software Engineer & Engineering Manager">
  <section class="about">
    <div class="about-inner">
      <!-- Headline + role — mirrors the home hero -->
      <header class="about-header">
        <h1 class="headline">
          HI, I'M <span class="accent">VITOR MARGIS</span>
        </h1>
        <p class="role">
          SOFTWARE ENGINEER &amp; ENGINEERING MANAGER at <span class="accent">ANGI</span>
          {' '}/<br class="role-break" />
          MENTORING at <span class="accent">ADPList</span>
        </p>
      </header>

      <!-- Bio with floating company logo decorations -->
      <div class="bio-wrap">
        <!-- Left-side decoration: Travix -->
        <div class="logo-float logo-float--left" aria-hidden="true">
          <span class="logo-badge">TRAVIX</span>
        </div>

        <!-- Bio copy -->
        <div class="bio">
          <p>
            I started out with a degree in Graphic Design, spending my early career
            at small design studios where I learned to obsess over craft and user
            experience.
          </p>
          <p>
            In 2014 I made the full pivot to web development — writing code turned out
            to be the fastest way to ship the ideas I cared about.
          </p>
          <p>
            Since then I've grown through a series of product companies:{' '}
            <a href="https://www.vizir.com.br" target="_blank" rel="noopener noreferrer">Vizir Software Studio</a>,{' '}
            <a href="https://www.travix.com" target="_blank" rel="noopener noreferrer">Travix International</a>,{' '}
            <a href="https://www.sesame.hr" target="_blank" rel="noopener noreferrer">Sesame</a>,{' '}
            and now{' '}
            <a href="https://www.instapro.nl" target="_blank" rel="noopener noreferrer">Instapro Group (Angi)</a>{' '}
            — where I lead engineering teams and still write code every day.
          </p>
        </div>

        <!-- Right-side decorations: Sesame + Instapro -->
        <div class="logo-float logo-float--right" aria-hidden="true">
          <span class="logo-badge">SESAME</span>
          <span class="logo-badge logo-badge--accent">INSTAPRO</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 56px);
    padding: 3rem 2rem;
  }

  .about-inner {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 800px;
    width: 100%;
  }

  /* Headline + role */
  .about-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .headline {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: bold;
    letter-spacing: 0.08em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .accent {
    color: var(--color-accent);
  }

  .role {
    font-size: clamp(0.65rem, 1.5vw, 0.85rem);
    letter-spacing: 0.12em;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .role-break {
    display: none;
  }

  /* Bio section */
  .bio-wrap {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 2rem;
  }

  .bio {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    line-height: 1.8;
    color: var(--color-muted);
  }

  .bio p {
    /* inherit */
  }

  .bio a {
    color: var(--color-text);
    border-bottom: 1px solid #333;
    transition: color 0.2s, border-color 0.2s;
  }

  .bio a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Floating logo decorations */
  .logo-float {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .logo-float--left {
    align-items: flex-end;
  }

  .logo-float--right {
    align-items: flex-start;
  }

  .logo-badge {
    writing-mode: vertical-rl;
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    color: #2a2a2a;
    border: 1px solid #1e1e1e;
    padding: 0.75rem 0.3rem;
    border-radius: 2px;
    user-select: none;
  }

  .logo-badge--accent {
    color: #3a2010;
    border-color: #2a1808;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .about {
      align-items: flex-start;
      padding-top: 2.5rem;
    }

    .role-break {
      display: inline;
    }

    .logo-float {
      display: none;
    }
  }
</style>
