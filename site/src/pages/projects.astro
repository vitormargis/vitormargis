---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects">
  <div class="page-stub">
    <p class="label">PROJECTS</p>
  </div>
</BaseLayout>

<style>
  .page-stub {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 56px);
  }

  .label {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--color-muted);
  }
</style>
